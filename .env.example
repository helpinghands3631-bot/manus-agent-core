# Manus Agent Core - Environment Configuration Template
# Copy this file to .env and fill in your API keys
chore: add .env.example configuration template

# xAI Grok API Key (Required for Grok integration)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Agent Configuration
AGENT_MAX_STEPS=25
AGENT_MEMORY_WINDOW=10
AGENT_LONG_TERM_PATH=./data/memory.json
AGENT_LOG_LEVEL=INFO

# Tool Configuration
TOOL_TIMEOUT_SECS=30

# LLM Provider (openai, groq, anthropic, ollama)
LLM_PROVIDER=groq
LLM_MODEL=mixtral-8x7b-32768
LLM_API_KEY=${GROQ_API_KEY}

# Optional: Additional LLM Providers
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OLLAMA_BASE_URL=http://localhost:11434

# Logging
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/agent.jsonl

# ── Comet / Opik Observability ───────────────────────────────────────────────
OPIK_API_KEY=your-comet-api-key-here
OPIK_WORKSPACE=your-comet-workspace-here
OPIK_PROJECT_NAME=manus-agent-platform
OPIK_CONSOLE_LOGGING_LEVEL=WARNING

# ── xAI (alternative to GROQ_API_KEY) ───────────────────────────────────────
XAI_API_KEY=your_xai_key_here
LLM_BASE_URL=https://api.x.ai/v1
LLM_MODEL=grok-2-latest
